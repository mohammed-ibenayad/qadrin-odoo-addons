<data>
    <template id="public_booking_page" name="Public Booking Page">
        <t t-call="web.layout">
            <t t-set="title" t-value="booking_type.name" />
            <div class="o_booking_public">
                <div class="container my-4">
                    <div class="row justify-content-center">
                        <div class="col-12 col-md-10 col-lg-8">
                            <h1 t-out="booking_type.name" />
                            <p class="text-muted" t-if="booking_type.requester_advice">
                                <t t-out="booking_type.requester_advice" />
                            </p>

                            <!-- Warning message -->
                            <div
                                t-if="booking_type.public_warning_msg"
                                class="alert alert-info"
                                role="alert"
                            >
                                <span t-field="booking_type.public_warning_msg" />
                            </div>

                            <!-- Booking form -->
                            <form
                                method="post"
                                t-att-action="'/book/%s/confirm' % access_token"
                                class="booking-form"
                            >
                                <input
                                    type="hidden"
                                    name="csrf_token"
                                    t-att-value="request.csrf_token()"
                                />
                                <input
                                    type="hidden"
                                    name="slot"
                                    id="selected_slot"
                                    required="True"
                                />

                                <!-- User details -->
                                <div class="card mb-4">
                                    <div class="card-header">
                                        <h3 class="mb-0">Your Details</h3>
                                    </div>
                                    <div class="card-body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label
                                                    for="name"
                                                    class="form-label"
                                                >Name *</label>
                                                <input
                                                    type="text"
                                                    name="name"
                                                    id="name"
                                                    class="form-control"
                                                    required="True"
                                                    t-att-value="name or ''"
                                                />
                                            </div>
                                            <div class="col-md-6">
                                                <label
                                                    for="email"
                                                    class="form-label"
                                                >Email *</label>
                                                <input
                                                    type="email"
                                                    name="email"
                                                    id="email"
                                                    class="form-control"
                                                    required="True"
                                                    t-att-value="email or ''"
                                                />
                                            </div>
                                            <div class="col-md-6">
                                                <label
                                                    for="phone"
                                                    class="form-label"
                                                >Phone</label>
                                                <input
                                                    type="tel"
                                                    name="phone"
                                                    id="phone"
                                                    class="form-control"
                                                    t-att-value="phone or ''"
                                                />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Calendar -->
                                <div class="card">
                                    <div class="card-header">
                                        <h3 class="mb-0">Select a Time Slot</h3>
                                    </div>
                                    <div class="card-body">
                                        <t t-call="resource_booking_public.scheduling_calendar_public" />
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Simplified scheduling calendar for public use (no modals, direct form submit) -->
    <template id="scheduling_calendar_public" name="Public Resource Booking Calendar">
        <t t-set="date_format" t-value="res_lang.date_format" />
        <t t-set="time_format" t-value="res_lang.time_format.replace(':%S', '')" />
        <t t-set="start_next" t-value="start + relativedelta(months=1)" />
        <t t-set="start_previous" t-value="start - relativedelta(months=1)" />
        <div class="o_booking_calendar">
            <div
                class="alert alert-danger"
                t-if="not slots"
            >
                No free slots found this month.
                <a
                    t-att-href="'/book/%s/%d/%d' % (access_token, start_next.year, start_next.month)"
                    class="alert-link"
                >
                    Try next month
                    <i class="fa fa-chevron-right" />
                </a>
            </div>
            <!-- Monthly calendar -->
            <div class="table-responsive-md">
                <table class="table text-center">
                    <thead class="table-dark">
                        <tr>
                            <th class="text-start">
                                <a
                                    t-att-href="'/book/%s/%d/%d' % (access_token, start_previous.year, start_previous.month)"
                                    class="btn btn-secondary"
                                    title="Previous month"
                                >
                                    <i class="fa fa-chevron-left" />
                                </a>
                            </th>
                            <th
                                class="align-middle"
                                colspan="5"
                                t-out="start.strftime('%B %Y')"
                            />
                            <th class="text-end">
                                <a
                                    t-att-href="'/book/%s/%d/%d' % (access_token, start_next.year, start_next.month)"
                                    class="btn btn-secondary"
                                    title="Next month"
                                >
                                    <i class="fa fa-chevron-right" />
                                </a>
                            </th>
                        </tr>
                    </thead>
                    <thead>
                        <tr>
                            <t t-foreach="calendar.iterweekdays()" t-as="weekday">
                                <th
                                    t-att-title="weekday_names[str(weekday + 1)]"
                                    t-out="weekday_names[str(weekday + 1)][:3]"
                                />
                            </t>
                        </tr>
                    </thead>
                    <tbody>
                        <t
                            t-foreach="calendar.monthdatescalendar(start.year, start.month)"
                            t-as="week"
                        >
                            <tr>
                                <t t-foreach="week" t-as="day">
                                    <td
                                        t-att-class="day.month != start.month and 'text-muted'"
                                    >
                                        <t
                                            t-if="day.month == start.month and slots.get(day)"
                                        >
                                            <!-- Day dropdown -->
                                            <div class="dropdown">
                                                <button
                                                    class="btn btn-primary dropdown-toggle"
                                                    type="button"
                                                    data-bs-toggle="dropdown"
                                                    aria-haspopup="true"
                                                    aria-expanded="false"
                                                    t-out="day.day"
                                                    t-attf-id="dropdown-trigger-#{day.isoformat()}"
                                                />
                                                <div
                                                    class="dropdown-menu slots-dropdown"
                                                    t-attf-aria-labelledby="dropdown-trigger-#{day.isoformat()}"
                                                >
                                                    <t
                                                        t-foreach="slots[day]"
                                                        t-as="slot"
                                                    >
                                                        <!-- Hour item to open confirmation -->
                                                        <button
                                                            class="dropdown-item slot-selector"
                                                            type="button"
                                                            t-att-data-slot="slot.isoformat()"
                                                            t-att-data-date="day.strftime(date_format)"
                                                            t-att-data-time="slot.strftime(time_format)"
                                                        >
                                                            <i class="fa fa-clock-o me-1" />
                                                            <t t-out="slot.strftime(time_format)" />
                                                        </button>
                                                    </t>
                                                </div>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <t t-out="day.day" />
                                        </t>
                                    </td>
                                </t>
                            </tr>
                        </t>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="7">
                                All times are displayed using this timezone:
                                <strong t-field="booking_type.resource_calendar_id.tz" />
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <!-- Selection confirmation -->
            <div class="mt-4 p-3 border rounded bg-light">
                <p class="mb-2">
                    <i class="fa fa-info-circle me-1" />
                    Selected slot:
                </p>
                <p class="mb-0">
                    <strong id="selected_date_display">-</strong>
                    <strong id="selected_time_display">-</strong>
                </p>
            </div>

            <!-- Submit button -->
            <div class="mt-4 text-center">
                <button
                    type="submit"
                    class="btn btn-primary btn-lg"
                    id="book_submit"
                    disabled="True"
                >
                    <i class="fa fa-check me-2" />
                    Confirm Booking
                </button>
            </div>

            <!-- JavaScript for slot selection -->
            <t t-set="date_format_js" t-value="date_format" />
            <t t-set="time_format_js" t-value="time_format" />
            <script type="text/javascript">
                document.addEventListener('DOMContentLoaded', function() {
                    // Slot selector buttons
                    document.querySelectorAll('.slot-selector').forEach(function(btn) {
                        btn.addEventListener('click', function(e) {
                            e.preventDefault();
                            var slot = btn.getAttribute('data-slot');
                            var date = btn.getAttribute('data-date');
                            var time = btn.getAttribute('data-time');

                            // Update hidden input
                            document.getElementById('selected_slot').value = slot;

                            // Update display
                            document.getElementById('selected_date_display').textContent = date + ' ';
                            document.getElementById('selected_time_display').textContent = time;

                            // Enable submit
                            document.getElementById('book_submit').disabled = false;
                        });
                    });
                });
            </script>
        </div>
    </template>

    <template id="public_booking_success" name="Public Booking Success">
        <t t-call="web.layout">
            <t t-set="title" t-value="'Booking Confirmed'" />
            <div class="container my-5">
                <div class="row justify-content-center">
                    <div class="col-12 col-md-8 col-lg-6 text-center">
                        <div class="alert alert-success">
                            <i class="fa fa-check-circle fa-3x mb-3" />
                            <h2>Booking Confirmed!</h2>
                            <p class="lead">
                                Your booking for
                                <strong t-out="booking_type.name" />
                                has been confirmed.
                            </p>
                        </div>

                        <div class="card mt-4">
                            <div class="card-body">
                                <h4 class="card-title">Booking Details</h4>
                                <ul class="list-unstyled text-start">
                                    <li class="mb-2">
                                        <strong>Type:</strong>
                                        <span t-out="booking_type.name" />
                                    </li>
                                    <li class="mb-2">
                                        <strong>Date:</strong>
                                        <span t-out="booking.start" t-options="{'widget': 'datetime'}" />
                                    </li>
                                    <li class="mb-2">
                                        <strong>Duration:</strong>
                                        <span t-field="booking.duration" t-options='{"widget": "float_time"}' />
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <div class="mt-4">
                            <a
                                href="/"
                                class="btn btn-primary"
                            >
                                Return to Homepage
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</data>

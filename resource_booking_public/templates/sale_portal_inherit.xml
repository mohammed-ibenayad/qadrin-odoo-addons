<odoo>
    <template
        id="sale_order_portal_content_booking"
        name="Booking link on Sale Order Portal"
        inherit_id="sale.sale_order_portal_content"
    >
        <xpath expr="//div[@id='introduction']" position="after">
            <t t-if="sale_order.booking_id">
                <div class="alert alert-primary mt-3 d-flex align-items-center justify-content-between" role="alert">
                    <div>
                        <i class="fa fa-calendar me-2"/>
                        <strong>Resource booking</strong>
                        <span class="ms-2" t-out="sale_order.booking_id.type_id.name"/>
                        <span
                            class="ms-2 text-muted small"
                            t-if="sale_order.booking_id.start"
                            t-out="sale_order.booking_id.start.strftime('%d %b %Y, %H:%M')"
                        />
                    </div>
                    <a
                        t-att-href="sale_order.booking_id.manage_url"
                        class="btn btn-sm btn-outline-primary"
                    >
                        Manage booking
                    </a>
                </div>
            </t>
        </xpath>
    </template>
</odoo>

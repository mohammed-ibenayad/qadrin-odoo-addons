<data>
    <record id="view_resource_booking_type_form_inherit" model="ir.ui.view">
        <field name="name">resource.booking.type.form.inherit</field>
        <field name="model">resource.booking.type</field>
        <field name="inherit_id" ref="resource_booking.resource_booking_type_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='main']" position="after">
                <group name="public_booking" string="Public Booking">
                    <field name="is_public"/>
                    <field
                        name="public_url"
                        widget="CopyClipboardChar"
                        readonly="1"
                        invisible="not is_public"
                    />
                    <button
                        name="action_regenerate_access_token"
                        type="object"
                        string="Regenerate Share Link"
                        class="btn-link"
                        confirm="Regenerating the token will invalidate the previously shared link. Continue?"
                        invisible="not is_public"
                    />
                    <field name="public_warning_msg" colspan="2" invisible="not is_public"/>
                </group>
            </xpath>
        </field>
    </record>
</data>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
      Behavior:
      - Event has embed_html → description hidden, embed renders in its place
      - Event has no embed_html → description renders normally

      The xpath targets `o_wevent_event_main_col` because that's the
      actual parent ID on this install (verified via DOM inspection).
      Different OCA layouts use different class/ID names, so this is
      the install-specific anchor.
    -->
    <template id="event_description_full_inherit_embed"
              inherit_id="website_event.event_description_full"
              name="Event Page: Custom Embed">

        <!-- Hide the description block when an embed is present. -->
        <xpath expr="//div[@t-field='event.description']" position="attributes">
            <attribute name="t-if">not event.embed_html</attribute>
        </xpath>

        <!-- Inject the embed in the same spot. -->
        <xpath expr="//div[@t-field='event.description']" position="after">
            <div t-if="event.embed_html"
                 class="o_wevent_event_custom_embed"
                 id="o_wevent_event_custom_embed">
                <t t-out="event.embed_html_safe"/>
            </div>
        </xpath>
    </template>
</odoo>
